#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR=$(cd "$(dirname "$0")/.." && pwd)
COMPOSE_FILE="$ROOT_DIR/doc/docker-compose.yml"

echo "[1/4] 构建后端 JAR..."
cd "$ROOT_DIR"
mvn -q -pl freshmall-gateway,freshmall-user,freshmall-thing,freshmall-order -am package -DskipTests

echo "[2/4] 构建本地镜像..."
docker compose -f "$COMPOSE_FILE" build

echo "[3/4] 启动服务..."
docker compose -f "$COMPOSE_FILE" up -d

echo "[4/4] 健康巡检..."
"$ROOT_DIR/doc/scripts/compose_health_audit.sh"

echo "[OK] 启动完成，网关地址: http://localhost:9100"